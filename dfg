import pygame
from pygame.locals import *
pygame.init()


screen = pygame.display.set_mode((700, 600))
font = pygame.font.SysFont('Constantia', 30)
screen.fill("grey")
font_uh = pygame.font.SysFont("Cascadia Code ExtraLight", 70, False)

def draw_text(text, font_uh, text_col, x, y): # just to write stuff
    img = font.render(text, True, text_col)
    screen.blit(img, (x, y)) 


clicked = False


class button():
		
	button_col = (255, 245, 206)
	hover_col = (255, 225, 255)
	click_col = (255, 230, 145)
	width = 350
	height = 70

	def __init__(self, x, y):
		self.x = x
		self.y = y
	
	def draw_button(self):

		global clicked
		action = False
		pos = pygame.mouse.get_pos()
		button_rect = Rect(self.x, self.y, self.width, self.height)

		if button_rect.collidepoint(pos):
			if pygame.mouse.get_pressed()[0] == 1:
				clicked = True
				pygame.draw.rect(screen, self.click_col, button_rect)
			elif pygame.mouse.get_pressed()[0] == 0 and clicked == True:
				clicked = False
				action = True
			else:
				pygame.draw.rect(screen, self.hover_col, button_rect)
		else:
			pygame.draw.rect(screen, self.button_col, button_rect)
		return action



flashcards = button(170, 180)
multipleChoice = button(170, 270)
typingTest = button(170, 360)
alphabet = button(600, 500)

def mainMenu():
  run = True
  while run:
   # draw_text('Learn Morse Code!' , font, (100, 0, 100), 120, 50)

	if flashcards.draw_button():
		print('Flashcards')
	if multipleChoice.draw_button():
		print('Multiple Choice')
	if alphabet.draw_button():
	    print('Alphabet')
	if typingTest.draw_button():
	    print('Typing Test')
 
	
	    for event in pygame.event.get():
		    if event.type == pygame.QUIT:
		    	run = False	
	         pygame.display.update()
pygame.quit()