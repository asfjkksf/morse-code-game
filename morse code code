import pygame 
pygame.init()

screen = pygame.display.set_mode((700, 600)) 
font = pygame.font.SysFont('Constantia', 30, False)
pygame.display.set_caption('Learn morse code!')
screen.fill("grey")



def draw_text(text, font, text_col, x, y): # just to write stuff
    img = font.render(text, True, text_col)
    screen.blit(img, (x, y)) 




def menu():
  run = True
  while run == True:
       draw_text('Learn Morse Code!' , font, (100, 0, 100), 120, 50)




       for event in pygame.event.get(): 
           if event.type == pygame.QUIT:
               run = False 
           pygame.display.update()  
  pygame.quit()   
menu()

